#

adbenv ()
{
	[[ $ANDROID_HOME \
	|| $PATH == */platform-tools/* \
	|| $LD_LIBRARY_PATH == */platform-tools/* ]] \
	&& return

	ANDROID_HOME=~/android
	PATH=$ANDROID_HOME/cmdline-tools/latest/bin:$PATH
	PATH=$ANDROID_HOME/platform-tools:$PATH
	PATH=$ANDROID_HOME/emulator:$PATH
	LD_LIBRARY_PATH=$ANDROID_HOME/platform-tools/lib64:$LD_LIBRARY_PATH
	export PATH LD_LIBRARY_PATH
}

studioenv ()
{
	cd ~/android-studio
	export _JAVA_AWT_WM_NONREPARENTING=1 # note: already set in master env
	export PATH=$PWD/jre/bin:$PATH
	export ANDROID_SDK_ROOT=$HOME/android-studio-sdk
	PATH=$HOME/android-studio-sdk/cmdline-tools/latest/bin:$PATH
}
